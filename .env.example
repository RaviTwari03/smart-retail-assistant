# ============================================================
# Smart Retail Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values for local dev.
# On Azure App Service these are set in the Environment Variables blade.
# NEVER commit .env to git.
# ============================================================

# ---------------------------
# Azure Blob Storage
# ---------------------------
# Found in: Azure Portal → Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Container name (must match what you created in Azure)
AZURE_BLOB_CONTAINER=knowledge-base

# ---------------------------
# PostgreSQL (Azure SQL / local)
# ---------------------------
# Local Docker Compose:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_retail_db
# Azure PostgreSQL example:
# DATABASE_URL=postgresql://adminuser:password@your-server.postgres.database.azure.com:5432/smart_retail_db

# ---------------------------
# OpenAI (for LLM synthesis in customer support agent)
# ---------------------------
OPENAI_API_KEY=sk-...

# ---------------------------
# Azure Bot Service (optional)
# ---------------------------
MICROSOFT_APP_ID=
APP_PASSWORD=
BOT_FRAMEWORK_REGION=global
